{
    "name":  "openclaw-companion",
    "private":  true,
    "version":  "0.1.0",
    "type":  "module",
    "description":  "Minimal Tauri v2-style companion shell for OpenClaw Windows Native.",
    "scripts":  {
                    "dev":  "tauri dev",
                    "build":  "tauri build",
                    "check:rust":  "cargo check --manifest-path src-tauri/Cargo.toml",
                    "fmt:rust":  "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
                    "dev:frontend":  "vite --host 127.0.0.1 --port 1420",
                    "build:frontend":  "vite build"
                },
    "dependencies":  {
                         "@tauri-apps/api":  "^2.0.0"
                     },
    "devDependencies":  {
                            "@tauri-apps/cli":  "^2.0.0",
                            "vite":  "^7.0.0"
                        }
}
